{
  "name": "agent-app",
  "version": "0.1.0",
  "private": true,
  "description": "A TypeScript starter for building Node-based agent applications.",
  "packageManager": "pnpm@10.31.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @agent-app/api dev",
    "dev:server": "pnpm --filter @agent-app/api dev:server",
    "dev:web": "pnpm --filter @agent-app/web exec next dev --port 3001",
    "build": "pnpm --filter @agent-app/api build",
    "build:web": "pnpm --filter @agent-app/web build",
    "build:all": "pnpm run build && pnpm run build:web",
    "db:check": "pnpm --filter @agent-app/api db:check",
    "db:inspect": "pnpm --filter @agent-app/api db:inspect",
    "db:migrate": "pnpm --filter @agent-app/api db:migrate",
    "evals:run": "pnpm --filter @agent-app/api evals:run",
    "rag:index": "pnpm --filter @agent-app/api rag:index",
    "smoke:cancel": "pnpm --filter @agent-app/api smoke:cancel",
    "start": "pnpm --filter @agent-app/api start",
    "start:server": "pnpm --filter @agent-app/api start:server",
    "task:replay": "pnpm --filter @agent-app/api task:replay",
    "check": "pnpm --filter @agent-app/api check",
    "check:web": "pnpm --filter @agent-app/web lint && pnpm run build:web",
    "check:all": "pnpm run check && pnpm run check:web"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
