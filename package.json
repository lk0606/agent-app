{
  "name": "agent-app",
  "version": "0.1.0",
  "private": true,
  "description": "A TypeScript starter for building Node-based agent applications.",
  "packageManager": "pnpm@10.31.0",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:server": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:server": "node dist/server.js",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "openai": "^6.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
