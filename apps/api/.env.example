APP_NAME=agent-app
NODE_ENV=development
HUNYUAN_API_KEY=
HUNYUAN_MODEL=hy3-preview
# hy3-preview 在 TokenHub；旧域名 api.hunyuan.cloud.tencent.com 上的 hunyuan-turbos-latest 等已下线
HUNYUAN_BASE_URL=https://tokenhub.tencentmaas.com/v1
AGENT_MAX_STEPS=3
AGENT_TOOL_CALL_BUDGET=2
SESSION_HISTORY_MESSAGE_LIMIT=8
SESSION_HISTORY_CHAR_BUDGET=4000
HTTP_FETCH_TIMEOUT_MS=8000
HTTP_FETCH_RETRIES=2
HTTP_FETCH_MAX_CHARS=4000
HTTP_FETCH_MAX_RESPONSE_BYTES=12000
HTTP_FETCH_ALLOWED_CONTENT_TYPES=text/html,text/plain,application/json,application/xhtml+xml
HTTP_FETCH_ALLOW_HOSTS=
HTTP_FETCH_DENY_HOSTS=localhost,127.0.0.1,0.0.0.0
READ_FILE_ROOT_DIR=
READ_FILE_MAX_BYTES=8192
READ_FILE_ALLOWED_EXTENSIONS=.txt,.md,.json,.yaml,.yml
READ_FILE_DENIED_BASENAMES=.env,.env.local,credentials.json
# list_dir 单次返回上限；沙箱根目录同 READ_FILE_ROOT_DIR（未设时默认 evals/fixtures）
LIST_DIR_MAX_ENTRIES=50
# search_docs 检索片段数与切块大小；索引根目录同 READ_FILE_ROOT_DIR
SEARCH_DOCS_MAX_RESULTS=3
SEARCH_DOCS_CHUNK_CHARS=500
PORT=3000
DATABASE_URL=postgres://agent:agent@127.0.0.1:5432/agent_app
